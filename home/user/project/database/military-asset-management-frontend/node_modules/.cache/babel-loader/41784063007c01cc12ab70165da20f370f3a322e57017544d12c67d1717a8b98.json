{"ast":null,"code":"import{useState,useEffect}from'react';import auth from'../services/auth';const useAuth=()=>{const[user,setUser]=useState(null);const[token,setToken]=useState(null);useEffect(()=>{const storedToken=localStorage.getItem('token');if(storedToken){setToken(storedToken);auth.getUser(storedToken).then(user=>setUser(user));}},[]);const login=(username,password)=>{auth.login(username,password).then(token=>{setToken(token);localStorage.setItem('token',token);auth.getUser(token).then(user=>setUser(user));});};const logout=()=>{setToken(null);setUser(null);localStorage.removeItem('token');};return{user,token,login,logout,isAuthenticated:!!token};};export default useAuth;","map":{"version":3,"names":["useState","useEffect","auth","useAuth","user","setUser","token","setToken","storedToken","localStorage","getItem","getUser","then","login","username","password","setItem","logout","removeItem","isAuthenticated"],"sources":["C:/Users/91636/OneDrive/Desktop/Neeeww/home/user/project/database/military-asset-management-frontend/src/hooks/useAuth.js"],"sourcesContent":["import { useState, useEffect } from 'react';\r\nimport auth from '../services/auth';\r\n\r\nconst useAuth = () => {\r\n  const [user, setUser] = useState(null);\r\n  const [token, setToken] = useState(null);\r\n\r\n  useEffect(() => {\r\n    const storedToken = localStorage.getItem('token');\r\n    if (storedToken) {\r\n      setToken(storedToken);\r\n      auth.getUser(storedToken).then((user) => setUser(user));\r\n    }\r\n  }, []);\r\n\r\n  const login = (username, password) => {\r\n    auth.login(username, password).then((token) => {\r\n      setToken(token);\r\n      localStorage.setItem('token', token);\r\n      auth.getUser(token).then((user) => setUser(user));\r\n    });\r\n  };\r\n\r\n  const logout = () => {\r\n    setToken(null);\r\n    setUser(null);\r\n    localStorage.removeItem('token');\r\n  };\r\n\r\n  return { user, token, login, logout, isAuthenticated: !!token };\r\n};\r\n\r\nexport default useAuth;\r\n"],"mappings":"AAAA,OAASA,QAAQ,CAAEC,SAAS,KAAQ,OAAO,CAC3C,MAAO,CAAAC,IAAI,KAAM,kBAAkB,CAEnC,KAAM,CAAAC,OAAO,CAAGA,CAAA,GAAM,CACpB,KAAM,CAACC,IAAI,CAAEC,OAAO,CAAC,CAAGL,QAAQ,CAAC,IAAI,CAAC,CACtC,KAAM,CAACM,KAAK,CAAEC,QAAQ,CAAC,CAAGP,QAAQ,CAAC,IAAI,CAAC,CAExCC,SAAS,CAAC,IAAM,CACd,KAAM,CAAAO,WAAW,CAAGC,YAAY,CAACC,OAAO,CAAC,OAAO,CAAC,CACjD,GAAIF,WAAW,CAAE,CACfD,QAAQ,CAACC,WAAW,CAAC,CACrBN,IAAI,CAACS,OAAO,CAACH,WAAW,CAAC,CAACI,IAAI,CAAER,IAAI,EAAKC,OAAO,CAACD,IAAI,CAAC,CAAC,CACzD,CACF,CAAC,CAAE,EAAE,CAAC,CAEN,KAAM,CAAAS,KAAK,CAAGA,CAACC,QAAQ,CAAEC,QAAQ,GAAK,CACpCb,IAAI,CAACW,KAAK,CAACC,QAAQ,CAAEC,QAAQ,CAAC,CAACH,IAAI,CAAEN,KAAK,EAAK,CAC7CC,QAAQ,CAACD,KAAK,CAAC,CACfG,YAAY,CAACO,OAAO,CAAC,OAAO,CAAEV,KAAK,CAAC,CACpCJ,IAAI,CAACS,OAAO,CAACL,KAAK,CAAC,CAACM,IAAI,CAAER,IAAI,EAAKC,OAAO,CAACD,IAAI,CAAC,CAAC,CACnD,CAAC,CAAC,CACJ,CAAC,CAED,KAAM,CAAAa,MAAM,CAAGA,CAAA,GAAM,CACnBV,QAAQ,CAAC,IAAI,CAAC,CACdF,OAAO,CAAC,IAAI,CAAC,CACbI,YAAY,CAACS,UAAU,CAAC,OAAO,CAAC,CAClC,CAAC,CAED,MAAO,CAAEd,IAAI,CAAEE,KAAK,CAAEO,KAAK,CAAEI,MAAM,CAAEE,eAAe,CAAE,CAAC,CAACb,KAAM,CAAC,CACjE,CAAC,CAED,cAAe,CAAAH,OAAO","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}